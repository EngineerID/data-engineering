# Copy to .env and adjust for local use (WSL paths recommended).

DATA_DIR=./data

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=def_learning
POSTGRES_USER=def_user
POSTGRES_PASSWORD=def_pass

SPARK_MASTER_URL=spark://localhost:7077
SPARK_MASTER_WEB_UI=http://localhost:8080

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Module 09 — local cloud emulators (LocalStack / fake-gcs-server / Azurite).
# Defaults match infra/docker-compose.yml; no real cloud credentials needed.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
GCS_ENDPOINT_URL=http://localhost:4443
GCP_PROJECT=def-local
AZURITE_BLOB_URL=http://127.0.0.1:10000
